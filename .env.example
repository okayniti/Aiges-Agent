# Copy this file to .env and fill in real values. .env is gitignored;
# .env.example is the template that's safe to commit.

# --- NEAR AI Cloud ---
# From https://cloud.near.ai (Sign in -> API Keys -> generate)
# Only needed for actual inference calls; the attestation report endpoint
# (agents/mock_attested_agent.py's live=True path) needs no key at all.
NEAR_AI_API_KEY=

# Gateway (chat completions, attestation report). Override to a direct
# completions endpoint (e.g. https://qwen35-122b.completions.near.ai/v1) to
# skip the gateway hop for a single model.
NEAR_AI_BASE_URL=https://cloud-api.near.ai/v1

# --- Groq (free, no card, used for actual agent reasoning) ---
# From https://console.groq.com (sign in with email or Google -> API Keys)
GROQ_API_KEY=
